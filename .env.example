# EpiCase environment variables
# Never commit .env to git.

# PostgreSQL
POSTGRES_DB=epicase
POSTGRES_USER=epicase
POSTGRES_PASSWORD=change-me-strong-password-here

# JWT (min 32 chars; generate with: openssl rand -hex 32)
JWT_SECRET=change-me-use-openssl-rand-hex-32-here

# CORS
# Dev:  http://localhost:5173
# Prod: http://epicase.vmeda.local,http://10.0.1.100
CORS_ORIGINS=http://localhost:5173

# Server
APP_VERSION=1.1.0
FIRST_RUN=true

# Environment
# dev: /api/docs enabled (Swagger UI)
# prod: /api/docs disabled
ENV=dev
