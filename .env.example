# ══════════════════════════════════════════════════════════════
# EpiCase — environment variables
# Copy to .env and fill in. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=epicase
POSTGRES_USER=epicase
POSTGRES_PASSWORD=change-me-strong-password-here

# ── JWT (min 32 chars! Generate: openssl rand -hex 32) ────────
JWT_SECRET=change-me-use-openssl-rand-hex-32-here

# ── CORS (ADDENDUM §T.8) ──────────────────────────────────────
# Dev:  http://localhost:5173
# Prod: http://epicase.vmeda.local,http://10.0.1.100  (LAN IPs, comma-separated)
CORS_ORIGINS=http://localhost:5173

# ── Server ────────────────────────────────────────────────────
APP_VERSION=1.1.0
FIRST_RUN=true

# ── Environment (BEST_PRACTICES §B.2.2 E-17) ──────────────────
# dev  → /api/docs открыт (Swagger UI)
# prod → /api/docs ОТКЛЮЧЁН (нельзя раскрывать схему API публично)
ENV=dev
